# ~/.bash_private - 私有配置（含密钥），不进 git 仓库
# 使用方法：cp ~/.bash_private.example ~/.bash_private，然后填入真实值
# ============================================================

# --- 阿里云 OSS ---
# 首次运行 oss 命令时，这些变量会被写入 ~/.ossutilconfig（600）作为凭据文件，
# 之后 ossutil 从配置文件读取，AK/SK 不会出现在命令行参数里（避免 ps 可见）。
# 更换凭据时：更新此文件后删除 ~/.ossutilconfig 重新生成。
export OSS_AK_ID="your_access_key_id"
export OSS_AK_SECRET="your_access_key_secret"
export OSS_ENDPOINT="cn-zhangjiakou.oss.aliyuncs.com"
